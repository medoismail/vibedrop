# VibeDrop Environment Variables

# Signaling server (defaults to wss://vibedrop-signaling.fly.dev)
# NEXT_PUBLIC_SIGNALING_URL=wss://vibedrop-signaling.fly.dev

# TURN server for users behind symmetric NATs / corporate firewalls
# Free options: metered.ca, Cloudflare TURN, or self-hosted coturn
# Without TURN, ~5-10% of users behind strict NATs cannot connect.
# NEXT_PUBLIC_TURN_URL=turn:a]relay.metered.ca:443?transport=tcp
# NEXT_PUBLIC_TURN_USERNAME=your-username
# NEXT_PUBLIC_TURN_CREDENTIAL=your-credential
